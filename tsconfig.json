{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "paths": {
      "~/*": ["./*"],
      "#app": ["node_modules/nuxt/dist/app/index.mjs"],
      "#build/*": [".nuxt/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.vue"],
  "exclude": ["node_modules", "dist", ".nuxt"]
}
